// UTC NextGen — Unsri Training Center
// Schema covers all 9 modules. Migrations are added per-module as they're built.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================================
// ENUMS
// =====================================================================

enum Role {
  SUPERADMIN
  LAB_ADMIN
  PROCTOR
  MAHASISWA
}

enum LessonType {
  VIDEO
  PDF
  TEXT
}

enum QuizKind {
  SECTION
  PRETEST
  FINAL
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  ESSAY
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum ExamSessionStatus {
  SCHEDULED
  ACTIVE
  SUBMITTED
  FORCE_ENDED
  EXPIRED
}

enum ViolationType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  COPY_PASTE
  RIGHT_CLICK
  MULTIPLE_FACES
  NO_FACE
  OTHER
}

enum PointEvent {
  REGISTER
  DAILY_LOGIN
  LESSON_COMPLETE
  QUIZ_PASS
  EXAM_PASS
  CERT_EARNED
  COURSE_UNLOCK
  MERCH_REDEEM
  ADMIN_ADJUST
  EVENT_ATTENDANCE
}

enum EventStatus {
  DRAFT // belum dipublikasikan
  PUBLISHED // tampil di landing & dashboard, belum dimulai
  ONGOING // event sedang berlangsung
  COMPLETED // event sudah selesai & poin sudah diberikan
  CANCELLED // dibatalkan
}

enum ProjectStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TorStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO
  COURSE
  EXAM
  BADGE
  SYSTEM
}

enum AssetCondition {
  GOOD
  NEEDS_REPAIR
  BROKEN
  DISPOSED
}

enum LabMemberRole {
  MEMBER
  ASSISTANT
}

enum MerchKind {
  PHYSICAL
  VOUCHER
}

enum DeliveryMethod {
  PICKUP
  SHIPPED
}

enum RedemptionStatus {
  PENDING
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PolicyEffect {
  ALLOW
  DENY
}

// =====================================================================
// AUTH (NextAuth.js v5 — JWT strategy, but adapter tables kept)
// =====================================================================

model User {
  id            String    @id @default(cuid())
  nim           String?   @unique
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  prodi         String?
  angkatan      Int?
  role          Role      @default(MAHASISWA)
  isActive      Boolean   @default(true)
  points        Int       @default(0)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  pointsLedger     PointsLedger[]
  enrollments      Enrollment[]
  quizAttempts     QuizAttempt[]
  examSessions     ExamSession[]
  certificates     Certificate[]
  userBadges       UserBadge[]
  notifications    Notification[]
  labMemberships   LabMember[]
  adminOfLabs      Lab[]             @relation("LabAdmin")
  lessonProgress   LessonProgress[]
  redemptions      MerchRedemption[]
  customRoles      UserCustomRole[]
  eventAttendances EventAttendance[]
  createdEvents    Event[]           @relation("EventCreator")

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================================
// LAB MANAGEMENT
// =====================================================================

model Lab {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  logoUrl     String?
  adminId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin                User?                 @relation("LabAdmin", fields: [adminId], references: [id])
  members              LabMember[]
  courses              Course[]
  tors                 Tor[]
  projects             Project[]
  assets               Asset[]
  certificateTemplates CertificateTemplate[]
  events               Event[]
}

model LabMember {
  id       String        @id @default(cuid())
  labId    String
  userId   String
  role     LabMemberRole @default(MEMBER)
  joinedAt DateTime      @default(now())

  lab  Lab  @relation(fields: [labId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([labId, userId])
  @@index([labId, role])
}

model Tor {
  id          String    @id @default(cuid())
  labId       String
  title       String
  contentJson Json
  status      TorStatus @default(DRAFT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  approvedAt  DateTime?

  lab Lab @relation(fields: [labId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(cuid())
  labId       String
  title       String
  description String?       @db.Text
  status      ProjectStatus @default(TODO)
  position    Int           @default(0)
  budget      Int           @default(0)
  budgetUsed  Int           @default(0)
  startsAt    DateTime?
  dueAt       DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lab        Lab         @relation(fields: [labId], references: [id], onDelete: Cascade)
  milestones Milestone[]
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  done        Boolean   @default(false)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id           String         @id @default(cuid())
  labId        String
  name         String
  code         String         @unique
  description  String?        @db.Text
  quantity     Int            @default(1)
  condition    AssetCondition @default(GOOD)
  acquiredAt   DateTime?
  acquiredCost Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lab Lab @relation(fields: [labId], references: [id], onDelete: Cascade)
}

// =====================================================================
// COURSE / LMS
// =====================================================================

model Course {
  id                String   @id @default(cuid())
  slug              String   @unique
  labId             String
  title             String
  description       String?  @db.Text
  thumbnailUrl      String?
  isLocked          Boolean  @default(false)
  pointPrice        Int      @default(0)
  requirePretest    Boolean  @default(false)
  passScore         Int      @default(70) // % for final exam
  // Cert numbering. Pattern tokens: {PREFIX} {YEAR} {MONTH} {SEQ} {SEQ4}.
  // Default pattern when null: "{PREFIX}/{YEAR}/{SEQ4}". Default prefix when null: "UTC".
  // Lets fakultas define formats like "FASILKOM-PEL/2025/0001" by setting prefix=FASILKOM-PEL.
  certNumberPrefix  String?
  certNumberPattern String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lab                 Lab                  @relation(fields: [labId], references: [id], onDelete: Cascade)
  sections            Section[]
  enrollments         Enrollment[]
  pretestQuiz         Quiz?                @relation("CoursePretest")
  finalQuiz           Quiz?                @relation("CourseFinal")
  certificates        Certificate[]
  certificateTemplate CertificateTemplate?
}

model Section {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  order     Int
  createdAt DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quiz    Quiz?    @relation("SectionQuiz")

  @@unique([courseId, order])
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  order       Int
  type        LessonType
  contentText String?    @db.Text // legacy / fallback plain text
  contentJson Json? // rich content (Tiptap doc) for TEXT lessons
  contentUrl  String?
  durationSec Int?
  createdAt   DateTime   @default(now())

  section  Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([sectionId, order])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// =====================================================================
// QUIZ & EXAM
// =====================================================================

model Quiz {
  id                String   @id @default(cuid())
  kind              QuizKind
  title             String
  minScore          Int      @default(70)
  maxAttempts       Int      @default(3)
  timerSec          Int? // null = no timer
  cooldownMinutes   Int?     @default(30) // null = no cooldown (hard limit). Otherwise rolling window.
  randomize         Boolean  @default(true)
  // Anti-cheat config (used by PRETEST/FINAL via ExamSession; SECTION quizzes ignore these).
  webcamEnabled     Boolean  @default(false)
  webcamIntervalSec Int      @default(60)
  maxViolations     Int      @default(3)
  createdAt         DateTime @default(now())

  // exactly one of these is set per quiz, depending on kind
  sectionId       String? @unique
  pretestCourseId String? @unique
  finalCourseId   String? @unique

  section       Section?      @relation("SectionQuiz", fields: [sectionId], references: [id], onDelete: Cascade)
  pretestCourse Course?       @relation("CoursePretest", fields: [pretestCourseId], references: [id], onDelete: Cascade)
  finalCourse   Course?       @relation("CourseFinal", fields: [finalCourseId], references: [id], onDelete: Cascade)
  questions     Question[]
  attempts      QuizAttempt[]
  examSessions  ExamSession[]
}

model Question {
  id     String       @id @default(cuid())
  quizId String
  type   QuestionType
  order  Int
  text   String       @db.Text
  points Int          @default(1)

  quiz    Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices Choice[]
  answers AnswerSubmission[]

  @@unique([quizId, order])
}

model Choice {
  id         String  @id @default(cuid())
  questionId String
  text       String  @db.Text
  isCorrect  Boolean @default(false)
  order      Int

  question Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  picks    AnswerSubmission[]
}

model QuizAttempt {
  id          String        @id @default(cuid())
  quizId      String
  userId      String
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  score       Int?
  passed      Boolean       @default(false)
  status      AttemptStatus @default(IN_PROGRESS)

  quiz    Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers AnswerSubmission[]

  @@index([userId, quizId])
}

model AnswerSubmission {
  id            String    @id @default(cuid())
  attemptId     String
  questionId    String
  choiceId      String?
  essayText     String?   @db.Text
  isCorrect     Boolean?
  pointsAwarded Int       @default(0)
  gradedById    String?
  gradedAt      DateTime?

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choice   Choice?     @relation(fields: [choiceId], references: [id])

  @@unique([attemptId, questionId])
}

// =====================================================================
// ENROLLMENT
// =====================================================================

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  progressPct Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// =====================================================================
// EXAM SESSION (proctored)
// =====================================================================

model ExamSession {
  id                String            @id @default(cuid())
  quizId            String
  userId            String
  status            ExamSessionStatus @default(SCHEDULED)
  startedAt         DateTime?
  endsAt            DateTime?
  submittedAt       DateTime?
  durationSec       Int // copied from Quiz.timerSec at creation
  webcamEnabled     Boolean           @default(false)
  webcamIntervalSec Int               @default(60)
  maxViolations     Int               @default(3)
  violationCount    Int               @default(0)
  score             Int?
  passed            Boolean           @default(false)
  attemptId         String?           @unique
  proctorMessage    String?           @db.Text
  proctorMessageAt  DateTime?
  createdAt         DateTime          @default(now())

  quiz       Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  violations ExamViolation[]
  snapshots  WebcamSnapshot[]

  @@index([status])
}

model ExamViolation {
  id            String        @id @default(cuid())
  examSessionId String
  type          ViolationType
  meta          Json?
  occurredAt    DateTime      @default(now())

  session ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
}

model WebcamSnapshot {
  id            String   @id @default(cuid())
  examSessionId String
  imageUrl      String
  capturedAt    DateTime @default(now())

  session ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
}

// =====================================================================
// GAMIFIKASI
// =====================================================================

model PointsLedger {
  id        String     @id @default(cuid())
  userId    String
  event     PointEvent
  delta     Int
  reason    String?
  refType   String?
  refId     String?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  iconClass   String // e.g. "fa-solid fa-medal"
  createdAt   DateTime @default(now())

  awards UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model MerchItem {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?   @db.Text
  imageUrl    String?
  pointPrice  Int
  stock       Int       @default(0) // -1 = unlimited
  active      Boolean   @default(true)
  kind        MerchKind @default(PHYSICAL) // PHYSICAL items support PICKUP/SHIPPED, VOUCHER is digital
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  redemptions MerchRedemption[]
}

model MerchRedemption {
  id              String           @id @default(cuid())
  userId          String
  merchItemId     String
  pointsSpent     Int
  status          RedemptionStatus @default(PENDING)
  // DB-level default lets migrations backfill existing rows safely; the API
  // replaces this with the nicer "UTC-RDM-XXXXXXXX" format on every new redemption.
  pickupCode      String           @unique @default(cuid())
  voucherCode     String? // for VOUCHER kind: filled in by admin and revealed to user
  deliveryMethod  DeliveryMethod   @default(PICKUP)
  deliveryAddress String?          @db.Text // when SHIPPED
  deliveryNotes   String?          @db.Text // user note (e.g. ukuran kaos)
  trackingNumber  String? // shipping tracking
  adminNotes      String?          @db.Text // notes from admin
  voucherSentAt   DateTime? // timestamp when voucher code was sent
  redeemedAt      DateTime         @default(now())
  // @default(now()) makes the column backfillable during migration.
  updatedAt       DateTime         @default(now()) @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchItem MerchItem @relation(fields: [merchItemId], references: [id], onDelete: Restrict)

  @@index([userId, redeemedAt])
  @@index([status, redeemedAt])
}

// =====================================================================
// CERTIFICATE
// =====================================================================

model CertificateTemplate {
  id            String   @id @default(cuid())
  courseId      String?  @unique
  labId         String?
  name          String
  backgroundUrl String
  fieldsJson    Json // positions for name, certNumber, date, etc
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lab    Lab?    @relation(fields: [labId], references: [id], onDelete: Cascade)
}

model Certificate {
  id         String   @id @default(cuid())
  certNumber String   @unique
  userId     String
  courseId   String
  qrPayload  String
  pdfUrl     String?
  issuedAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// =====================================================================
// NOTIFICATION
// =====================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String           @db.Text
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// =====================================================================
// RBAC: Permissions, Policies, Custom Roles (Phase 9)
// =====================================================================
// Konsep:
// - Permission: atom kapabilitas (e.g. "lab.edit"). Katalog dimuat saat seed.
// - Policy: bundle Permission, bisa di-attach ke banyak Role.
// - CustomRole: role custom yang bisa dibuat tanpa batas. Setiap CustomRole punya:
//     * baseRole (enum Role) — fallback untuk gate level-1 (sidebar, dll)
//     * permissions (langsung) — rule custom per role
//     * policies — bundle reusable
// - UserCustomRole: assign custom role ke user (selain base role).
// Effect ALLOW/DENY: DENY menang. Aturan resolusi ada di src/lib/abac.ts.

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  category    String
  label       String
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())

  policyPermissions PolicyPermission[]
  rolePermissions   CustomRolePermission[]

  @@index([category])
}

model Policy {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions  PolicyPermission[]
  rolePolicies CustomRolePolicy[]
}

model PolicyPermission {
  id           String       @id @default(cuid())
  policyId     String
  permissionId String
  effect       PolicyEffect @default(ALLOW)

  policy     Policy     @relation(fields: [policyId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([policyId, permissionId])
}

model CustomRole {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  baseRole    Role
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions CustomRolePermission[]
  policies    CustomRolePolicy[]
  userRoles   UserCustomRole[]

  @@index([baseRole])
}

model CustomRolePermission {
  id           String       @id @default(cuid())
  customRoleId String
  permissionId String
  effect       PolicyEffect @default(ALLOW)

  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, permissionId])
}

model CustomRolePolicy {
  id           String @id @default(cuid())
  customRoleId String
  policyId     String

  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  policy     Policy     @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, policyId])
}

model UserCustomRole {
  id           String   @id @default(cuid())
  userId       String
  customRoleId String
  assignedAt   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([userId, customRoleId])
  @@index([userId])
}

// =====================================================================
// EVENT / CAMPAIGN
// =====================================================================
// Event/kampanye yang bisa diumumkan di landing page (isPublic=true) dan
// dashboard mahasiswa. Mahasiswa melakukan presensi di akhir event lewat
// kode kehadiran. Saat admin memfinalisasi event, semua presensi yang valid
// otomatis diberi poin sebesar `pointReward` (PointEvent.EVENT_ATTENDANCE).
// `status` dapat diubah manual sebagai override, tapi normalnya mengikuti
// transisi: DRAFT -> PUBLISHED -> ONGOING -> COMPLETED.
model Event {
  id                 String      @id @default(cuid())
  slug               String      @unique
  title              String
  description        String?     @db.Text
  posterUrl          String?
  location           String?
  // Waktu mulai/akhir event. attendanceOpensAt/closesAt mengatur jendela
  // input presensi (default: sama dengan startsAt..endsAt + 1 jam).
  startsAt           DateTime
  endsAt             DateTime
  attendanceOpensAt  DateTime?
  attendanceClosesAt DateTime?
  // Kode presensi yang dibagikan ke peserta saat event (mis. "UTC2025-A1").
  // Bisa di-rotate kapan saja oleh admin. null = check-in tanpa kode (mode terbuka).
  attendanceCode     String?
  // Custom reward — admin bebas set per event. 0 = event tanpa poin.
  pointReward        Int         @default(50)
  status             EventStatus @default(DRAFT)
  // Tampilkan di landing page publik (selain dashboard internal).
  isPublic           Boolean     @default(true)
  // Lab penyelenggara (opsional — null = event UTC pusat).
  labId              String?
  createdById        String?
  // Stempel waktu finalisasi (saat poin sudah didistribusi). Mencegah double-award.
  finalizedAt        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  lab         Lab?              @relation(fields: [labId], references: [id], onDelete: SetNull)
  createdBy   User?             @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  attendances EventAttendance[]

  @@index([status, startsAt])
  @@index([isPublic, status])
}

model EventAttendance {
  id            String    @id @default(cuid())
  eventId       String
  userId        String
  checkedInAt   DateTime  @default(now())
  note          String?   @db.Text // feedback singkat / catatan kehadiran
  pointsAwarded Int       @default(0) // diisi saat event difinalisasi
  awardedAt     DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, checkedInAt])
}
