# ===== Database (PostgreSQL local via docker-compose) =====
DATABASE_URL="postgresql://utc:utc_dev_password@localhost:5432/utc_nextgen?schema=public"

# ===== NextAuth.js v5 =====
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-32-byte-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ===== Email (Resend) =====
# Sign up at https://resend.com, then create an API key
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="UTC NextGen <noreply@utc.unsri.ac.id>"

# ===== Uploadthing (file/video upload) =====
# Sign up at https://uploadthing.com, copy token from dashboard
UPLOADTHING_TOKEN="ut_xxxxxxxxxxxxxxxxxxxx"

# ===== App config =====
NEXT_PUBLIC_APP_NAME="UTC NextGen"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== Google Gemini (AI analyst untuk modul Analytics) =====
# Dapatkan API key gratis di https://aistudio.google.com/app/apikey — opsional, fitur AI insight nonaktif kalau kosong.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
