# =====================================================================
# Environment variables untuk PRODUCTION (Vercel)
# Copy semua ini ke Vercel Dashboard -> Settings -> Environment Variables
# =====================================================================

# ===== Database (PostgreSQL — Neon / Supabase / Vercel Postgres) =====
# DATABASE_URL pakai connection pooling (pgbouncer) untuk runtime serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.provider.com/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# DIRECT_URL pakai koneksi langsung — dipakai untuk `prisma migrate deploy`
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.provider.com/DB?sslmode=require"

# ===== NextAuth.js v5 =====
# WAJIB: generate sekali pakai `openssl rand -base64 32`
AUTH_SECRET="GANTI-DENGAN-32-BYTE-RANDOM"
# Set ke URL produksi (https). Vercel otomatis menyediakan VERCEL_URL, tapi explicit AUTH_URL lebih aman.
AUTH_URL="https://utc-nextgen.vercel.app"
AUTH_TRUST_HOST="true"

# ===== Email (Resend) =====
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="UTC NextGen <noreply@utc.unsri.ac.id>"

# ===== Uploadthing (kalau dipakai) =====
UPLOADTHING_TOKEN="ut_xxxxxxxxxxxxxxxxxxxx"

# ===== App config =====
NEXT_PUBLIC_APP_NAME="UTC NextGen"
NEXT_PUBLIC_APP_URL="https://utc-nextgen.vercel.app"

# ===== Google Gemini =====
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
